{
  "$schema": "http://json.schemastore.org/template",
  "author": "Modulith",
  "classifications": ["Modulith", "Slice", "Feature", "Command"],
  "identity": "Modulith.CommandSlice",
  "name": "Modulith Command Slice",
  "shortName": "modulith-command-slice",
  "description": "Scaffolds the six files of a command/write vertical feature slice inside an existing module.",
  "sourceName": "FeatureName",
  "symbols": {
    "module": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "ModuleName",
      "isRequired": true,
      "description": "The PascalCase module name this command slice belongs to (e.g. Catalog, Orders)."
    },
    "moduleNameLower": {
      "type": "derived",
      "valueSource": "module",
      "valueTransform": "lowerCaseInvariant",
      "replaces": "modulenamelower"
    },
    "featureNameLower": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "lowerCaseInvariant",
      "replaces": "featurenamelower"
    }
  },
  "sources": [
    {
      "source": "./Features/FeatureName",
      "target": ".",
      "include": ["**/*"],
      "exclude": [".template.config/**"]
    }
  ]
}
