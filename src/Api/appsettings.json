{
  "AllowedHosts": "*",

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.OpenTelemetry"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "OpenTelemetry"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "Modulith.Api"
    }
  },

  "Jwt": {
    "Issuer": "https://api.modulith.dev",
    "Audience": "modulith-api"
  },

  "FeatureManagement": {},

  "Modules": {
    "Notifications": {
      "ExternalLoginConfirmationUrlTemplate": "http://localhost:5173/auth/google/confirm?token={token}"
    },
    "Users": {
      "AdminBootstrap": {
        "Enabled": false,
        "Email": null
      },
      "TermsOfServiceVersion": "1.0",
      "PrivacyPolicyVersion": "1.0",
      "Google": {
        "ClientId": ""
      }
    }
  }
}
