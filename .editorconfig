root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,props,targets,xml}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.cs]
# File-scoped namespaces — required
csharp_style_namespace_declarations = file_scoped:error

# No regions
dotnet_diagnostic.IDE0065.severity = error

# Prefer primary constructors where applicable (suggestion only — not an error)
csharp_style_prefer_primary_constructors = true:suggestion

# Expression body preferences
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Braces
csharp_prefer_braces = true:warning

# Trailing commas
dotnet_style_allow_multiple_blank_lines_experimental = false:warning

# Organize usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Naming conventions
dotnet_naming_rule.private_fields_no_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_no_underscore.style = camel_case_style
dotnet_naming_rule.private_fields_no_underscore.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_case_style.capitalization = camel_case

# Severity overrides to keep strict build quiet on generated/imported code
dotnet_diagnostic.CA1062.severity = none

# MA0048: dot-notation file names (CreateProduct.Command.cs → CreateProductCommand) are
# an intentional slice convention — the rule would require renaming every slice file.
dotnet_diagnostic.MA0048.severity = none

# MA0004: ConfigureAwait(false) — ASP.NET Core has no SynchronizationContext, so this
# is noise in application code. Already applied manually in shared infrastructure.
dotnet_diagnostic.MA0004.severity = none

# S1144: EF Core materializes entities by setting private properties via reflection;
# these setters appear unused to static analysis but are required for DB hydration.
dotnet_diagnostic.S1144.severity = none

# S2094: Empty Wolverine message records (e.g. SweepExpiredTokens) are intentional
# trigger types with no payload — they are not candidates for interfaces.
dotnet_diagnostic.S2094.severity = none

# S2068: Design-time IDesignTimeDbContextFactory files contain localhost dev credentials
# for "dotnet ef migrations" tooling. Not production code.
dotnet_diagnostic.S2068.severity = none

# MA0051: EF Core migration Up/Down methods routinely exceed 60 lines; method-length
# limits are also subjective for application handler code.
dotnet_diagnostic.MA0051.severity = none

# S1118: 'public partial class Program { }' is required for WebApplicationFactory<Program>
# in integration tests — it is not a utility class in the traditional sense.
dotnet_diagnostic.S1118.severity = none

# MA0049: 'SmokeTests' class in 'Modulith.SmokeTests' namespace — intentional naming.
dotnet_diagnostic.MA0049.severity = none
