{
  "permissions": {
    "allow": [
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet ef migrations add:*)",
      "Bash(dotnet ef migrations list:*)",
      "Bash(dotnet ef migrations script:*)",
      "Bash(dotnet list package:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "ask": [
      "Bash(dotnet ef database update:*)",
      "Bash(dotnet ef migrations remove:*)",
      "Bash(dotnet add package:*)",
      "Bash(dotnet remove package:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Write(**/Directory.Packages.props)",
      "Write(**/Directory.Build.props)",
      "Write(**/global.json)",
      "Write(**/*.sln)",
      "Edit(**/Directory.Packages.props)",
      "Edit(**/Directory.Build.props)",
      "Edit(**/global.json)"
    ],
    "deny": [
      "Bash(dotnet ef database drop:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Write(**/docs/adr/**)",
      "Edit(**/docs/adr/**)",
      "Write(**/appsettings.Production.json)",
      "Edit(**/appsettings.Production.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-paths.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-dotnet.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/slice-completeness.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-format.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-gate.sh"
          }
        ]
      }
    ]
  }
}
